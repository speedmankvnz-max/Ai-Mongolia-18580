.cinfo{display:grid;grid-template-columns:1fr 1fr;gap:6rem;align-items:start;margin-top:5rem;padding-top:3rem;border-top:1.5px solid rgba(8,8,8,.18);}
.cleft p{font-size:1.05rem;font-weight:300;opacity:.65;line-height:1.8;margin-bottom:.8rem;}
.cleft p strong{font-weight:600;opacity:1;}
.cadr{margin-top:1.5rem;padding:1.5rem;background:rgba(8,8,8,.08);border:1px solid rgba(8,8,8,.12);}
.cadr p{font-size:.9rem;font-weight:300;opacity:.65;line-height:1.8;margin-bottom:0;}
.cadr strong{font-weight:700;font-family:'Barlow Condensed',sans-serif;font-size:1rem;letter-spacing:.05em;display:block;margin-bottom:.5rem;}
.cbtns{display:flex;flex-direction:column;gap:1rem;}
.cbtn{display:flex;align-items:center;gap:1.2rem;padding:1.2rem 2rem;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.82rem;letter-spacing:.18em;text-transform:uppercase;text-decoration:none;cursor:none;transition:all .35s;position:relative;overflow:hidden;}
.cbtn.bk{background:var(--black);color:var(--gold);}
.cbtn.bk::before{content:'';position:absolute;inset:0;background:var(--gold-rich);transform:scaleX(0);transform-origin:left;transition:transform .4s cubic-bezier(.76,0,.24,1);}
.cbtn.bk:hover::before{transform:scaleX(1);}
.cbtn.bk:hover{color:var(--black);}
.cbtn.ol{background:transparent;color:var(--black);border:1.5px solid rgba(8,8,8,.35);}
.cbtn.ol:hover{background:var(--black);color:var(--gold);}
.cbtn span{position:relative;z-index:1;}
.cbtn-ico{font-size:1.3rem;position:relative;z-index:1;}
.phone-block{margin-top:1.5rem;padding:1.5rem 2rem;background:var(--black);display:flex;align-items:center;gap:1rem;}
.phone-num{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.8rem;color:var(--gold);letter-spacing:.04em;}
.phone-label{font-family:'Barlow Condensed',sans-serif;font-weight:600;font-size:.6rem;letter-spacing:.25em;text-transform:uppercase;opacity:.4;color:var(--white);display:block;}

/* FOOTER */
footer{background:var(--black);color:rgba(255,255,255,.2);padding:2.5rem 3rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;border-top:1px solid rgba(255,255,255,.05);}
