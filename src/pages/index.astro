<script>
// Cursor
const c=document.getElementById('cur'),c2=document.getElementById('cur2');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;c.style.left=mx+'px';c.style.top=my+'px';});
(function a(){rx+=(mx-rx)*.13;ry+=(my-ry)*.13;c2.style.left=rx+'px';c2.style.top=ry+'px';requestAnimationFrame(a);})();
document.querySelectorAll('a,button,.svc,.wc,.sc,.pf-item,.ps,.price-card,.rev-card,.rev-mini').forEach(el=>{
  el.addEventListener('mouseenter',()=>document.body.classList.add('ch'));
  el.addEventListener('mouseleave',()=>document.body.classList.remove('ch'));
});
document.querySelectorAll('section.D,section.M,footer,.ticker').forEach(s=>{
  new IntersectionObserver(entries=>{
    entries.forEach(e=>{
      const active=document.querySelector('section.D:hover,section.M:hover');
      if(e.isIntersecting)document.body.classList.add('dark-cur');
      else{
        let any=false;
        document.querySelectorAll('section.D,section.M,footer,.ticker').forEach(x=>{const r=x.getBoundingClientRect();if(r.top<window.innerHeight&&r.bottom>0)any=true;});
        if(!any)document.body.classList.remove('dark-cur');
      }
    });
  },{threshold:.01}).observe(s);
});

// Scroll progress
const pr=document.getElementById('prog');
window.addEventListener('scroll',()=>{pr.style.width=(window.scrollY/(document.body.scrollHeight-window.innerHeight)*100)+'%';});

// Reveal
const obs=new IntersectionObserver(entries=>{
  entries.forEach((e,i)=>{if(e.isIntersecting){setTimeout(()=>e.target.classList.add('on'),i*70);obs.unobserve(e.target);}});
},{threshold:.07});
document.querySelectorAll('.r').forEach(el=>obs.observe(el));

// Ticker duplicate
const tt=document.getElementById('tt');
tt.innerHTML+=tt.innerHTML;

// Parallax
const hbg=document.querySelector('.hbg');
window.addEventListener('scroll',()=>{if(hbg)hbg.style.transform=`translate(-50%,calc(-50% + ${window.scrollY*.28}px))`;});
</script>
