/* WHY */
#why{background:var(--black);color:var(--white);}
.why-g{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5px;background:rgba(255,255,255,.07);margin-top:4rem;}
.wc{background:var(--black2);padding:3rem 2.5rem;transition:background .3s;}
.wc:hover{background:var(--black3);}
.wn{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:3.8rem;color:rgba(200,160,32,.1);line-height:1;display:block;margin-bottom:1.2rem;transition:color .3s;}
