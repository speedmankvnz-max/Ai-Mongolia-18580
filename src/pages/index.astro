.rev-sub{font-size:1rem;font-weight:300;opacity:.5;max-width:280px;line-height:1.7;}
.rev-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.5px;background:rgba(255,255,255,.06);}
.rev-card{background:var(--black2);padding:2rem;transition:background .3s;position:relative;}
.rev-card:hover{background:var(--black3);}
.rev-stars{color:var(--gold);font-size:.9rem;margin-bottom:.8rem;letter-spacing:.15em;}
.rev-text{font-size:.88rem;font-weight:300;opacity:.65;line-height:1.75;margin-bottom:1.2rem;font-style:italic;}
.rev-author{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.75rem;letter-spacing:.12em;text-transform:uppercase;color:var(--gold);display:block;}
.rev-role{font-family:'Barlow Condensed',sans-serif;font-size:.6rem;letter-spacing:.12em;text-transform:uppercase;opacity:.3;display:block;margin-top:.2rem;}
.rev-scroll-row{margin-top:3rem;overflow:hidden;}
.rev-scroll-track{display:flex;gap:1.5px;animation:revscroll 45s linear infinite;}
.rev-scroll-track:hover{animation-play-state:paused;}
.rev-mini{background:var(--black2);padding:1.5rem 1.8rem;min-width:280px;flex-shrink:0;}
.rev-mini .rev-stars{font-size:.75rem;margin-bottom:.5rem;}
.rev-mini .rev-text{font-size:.82rem;margin-bottom:.8rem;}
.rev-mini .rev-author{font-size:.68rem;}
